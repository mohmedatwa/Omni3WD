<?xml version="1.0"?>

<robot  xmlns:xacro="http://ros.org/wiki/xacro">

    <xacro:macro name="wheel_link" params="num">
        <link name="wheel_link_${num}">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="blue"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </collision>
            <xacro:cylinder_inertia m="0.50" r="${wheel_radius}" l="${wheel_length}"
                                    o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0" />
            
        </link>
        <joint name="wheel_joint${num}" type="continuous">
            <parent link="base_link" />
            <child link="wheel_link_${num}" />
            <origin 
                xyz="${(base_radius+wheel_length/2)*cos(num*pi*2/3)} ${(base_radius+wheel_length/2)*sin(num*pi*2/3)} 0" 
                rpy="0 0 ${(num*pi*2/3)+pi/2}" />
            <axis xyz="0 1 0" />
        </joint>

    </xacro:macro>
    <xacro:wheel_link num="0" />
    <xacro:wheel_link num="1" />
    <xacro:wheel_link num="2"/>

</robot>