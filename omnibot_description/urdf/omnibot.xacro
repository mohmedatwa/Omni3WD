<?xml version="1.0"?>

<robot name="omnibot" xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:include filename="$(find omnibot_description)/urdf/common_properties.xacro" />
    <xacro:include filename="$(find omnibot_description)/urdf/mech/omnibot_base.xacro" />
    <xacro:include filename="$(find omnibot_description)/urdf/mech/omnibot_wheel.xacro" />
    <xacro:include filename="$(find omnibot_description)/urdf/omnibot_ros2_control.xacro" />
    <xacro:include filename="$(find omnibot_description)/urdf/omnibot_gazebo.xacro" />
</robot>